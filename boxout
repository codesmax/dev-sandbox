#!/usr/bin/env bash
set -euo pipefail

# ─── Config ────────────────────────────────────────────────────────────────────
BOXOUT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BOXOUT_IMAGE="${BOXOUT_IMAGE:-boxout:latest}"
PROXY_CONTAINER="boxout-socket-proxy"
PROXY_NETWORK="boxout-proxy-net"
DOCKER_HOST_IN_CONTAINER="tcp://boxout-socket-proxy:2375"
HOME_VOLUME="boxout-home"

# ─── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'

# ─── Helpers ───────────────────────────────────────────────────────────────────
log()  { echo -e "${GREEN}[boxout]${NC} $*"; }
warn() { echo -e "${YELLOW}[boxout]${NC} $*"; }
die()  { echo -e "${RED}[boxout]${NC} $*" >&2; exit 1; }

usage() {
  cat <<EOF
Usage: boxout [options] <command> [args...]

Run a command inside an isolated dev sandbox container.
The current directory is bind-mounted as /workspace.

Commands:
  stop              Stop the Docker socket proxy (compose down)
  clean             Stop the proxy and remove its volumes (compose down -v)

Options:
  -h, --help        Show this help
  --no-proxy        Skip Docker socket proxy (no docker/compose access)
  --build           Rebuild the boxout image before running
  --image IMAGE     Use a specific boxout image (default: $BOXOUT_IMAGE)
  --allow-any-dir   Skip trusted-path check (override for one-off use)
  -p, --port MAPPING  Forward a port (HOST:CONTAINER). Can be repeated.

Examples:
  boxout claude              # Launch Claude Code
  boxout codex               # Launch Codex CLI
  boxout bash                # Drop into a shell
  boxout npm install         # Run any command in the sandbox
  boxout -p 8081:8081 claude # Expose Expo/Metro on port 8081
  boxout -p 3000:3000 -p 8081:8081 bash  # Multiple ports

Environment variables forwarded into sandbox:
  ANTHROPIC_API_KEY, OPENAI_API_KEY, GITHUB_TOKEN, NPM_TOKEN

Trusted paths:
  boxout refuses to run unless the current directory is inside a configured
  trusted path. Add allowed roots (one per line) to:
    ~/.config/boxout/trusted-paths
  or set BOXOUT_TRUSTED_PATHS as a colon-separated list.
  Use --allow-any-dir to bypass for a single invocation.
EOF
}

# ─── Trusted-paths check ───────────────────────────────────────────────────────
# Reads allowed roots from ~/.config/boxout/trusted-paths (one per line,
# # comments and blank lines ignored) and from BOXOUT_TRUSTED_PATHS (colon-
# separated). Exits if no trusted paths are configured at all (unless the
# caller has set ALLOW_ANY_DIR=true via --allow-any-dir).
assert_trusted_path() {
  [[ "${ALLOW_ANY_DIR:-false}" == "true" ]] && return 0

  local trusted_paths=() cwd p config_file="$HOME/.config/boxout/trusted-paths"

  if [[ -f "$config_file" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -z "$line" || "$line" == "#"* ]] && continue
      trusted_paths+=("$line")
    done < "$config_file"
  fi

  if [[ -n "${BOXOUT_TRUSTED_PATHS:-}" ]]; then
    IFS=':' read -ra _env_paths <<< "$BOXOUT_TRUSTED_PATHS"
    trusted_paths+=("${_env_paths[@]}")
  fi

  if [[ ${#trusted_paths[@]} -eq 0 ]]; then
    die "No trusted paths configured.\n" \
        "Add allowed roots (one per line) to ~/.config/boxout/trusted-paths\n" \
        "or set BOXOUT_TRUSTED_PATHS (colon-separated).\n" \
        "Use --allow-any-dir to bypass for a single invocation."
  fi

  cwd="$(pwd)"
  for p in "${trusted_paths[@]}"; do
    p="${p%/}"   # strip trailing slash for reliable prefix matching
    [[ "$cwd" == "$p" || "$cwd" == "$p/"* ]] && return 0
  done

  die "Refusing to run: '$(pwd)' is not inside a trusted path.\n" \
      "Add it (or a parent directory) to ~/.config/boxout/trusted-paths\n" \
      "or set the BOXOUT_TRUSTED_PATHS env var (colon-separated).\n" \
      "Use --allow-any-dir to bypass for a single invocation."
}

# ─── Parse args ────────────────────────────────────────────────────────────────
USE_PROXY=true
BUILD=false
ALLOW_ANY_DIR=false
PORT_MAPPINGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)        usage; exit 0 ;;
    --no-proxy)       USE_PROXY=false; shift ;;
    --build)          BUILD=true; shift ;;
    --image)          BOXOUT_IMAGE="$2"; shift 2 ;;
    --allow-any-dir)  ALLOW_ANY_DIR=true; shift ;;
    -p|--port)        PORT_MAPPINGS+=("$2"); shift 2 ;;
    --)               shift; break ;;
    -*)               die "Unknown option: $1" ;;
    *)                break ;;
  esac
done

[[ $# -eq 0 ]] && { usage; exit 1; }

# ─── Subcommands ──────────────────────────────────────────────────────────────
if [[ "$1" == "stop" ]]; then
  log "Stopping Docker socket proxy..."
  docker compose -f "$BOXOUT_DIR/docker-compose.yml" down
  exit 0
fi

if [[ "$1" == "clean" ]]; then
  log "Stopping Docker socket proxy and removing volumes..."
  docker compose -f "$BOXOUT_DIR/docker-compose.yml" down -v
  exit 0
fi

# ─── Trusted-path guard ────────────────────────────────────────────────────────
assert_trusted_path

# ─── Build image if needed ─────────────────────────────────────────────────────
if $BUILD || ! docker image inspect "$BOXOUT_IMAGE" &>/dev/null; then
  log "Building boxout image: $BOXOUT_IMAGE"
  docker build -t "$BOXOUT_IMAGE" "$BOXOUT_DIR"
fi

# ─── Ensure home volume exists and is owned by the calling user ────────────────
if ! docker volume inspect "$HOME_VOLUME" &>/dev/null; then
  docker run --rm \
    -v "$HOME_VOLUME:/home/boxout" \
    alpine chown "1000:1000" /home/boxout
fi

# ─── Ensure proxy is running ───────────────────────────────────────────────────
if $USE_PROXY; then
  if ! docker container inspect "$PROXY_CONTAINER" &>/dev/null 2>&1 || \
     [[ "$(docker inspect -f '{{.State.Running}}' "$PROXY_CONTAINER" 2>/dev/null)" != "true" ]]; then
    log "Starting Docker socket proxy..."
    docker compose -f "$BOXOUT_DIR/docker-compose.yml" up -d
    # Brief wait for proxy to be ready
    sleep 1
  fi
fi

# ─── Collect env vars to forward ───────────────────────────────────────────────
env_flags=()
for var in ANTHROPIC_API_KEY OPENAI_API_KEY GITHUB_TOKEN NPM_TOKEN; do
  [[ -n "${!var:-}" ]] && env_flags+=(-e "${var}=${!var}")
done

# ─── Build docker run args ─────────────────────────────────────────────────────
port_flags=()
for mapping in "${PORT_MAPPINGS[@]+"${PORT_MAPPINGS[@]}"}"; do
  port_flags+=(-p "$mapping")
done

run_args=(
  --rm
  --interactive
  --tty
  -v "$(pwd):/workspace"
  -v "$HOME_VOLUME:/home/boxout"
  -w /workspace
  "${env_flags[@]+"${env_flags[@]}"}"
  "${port_flags[@]+"${port_flags[@]}"}"
)

if $USE_PROXY; then
  run_args+=(
    --network "$PROXY_NETWORK"
    -e "DOCKER_HOST=${DOCKER_HOST_IN_CONTAINER}"
    # HOST_PWD exposes the real host path so that compose bind mounts resolve
    # correctly — the host daemon resolves paths on the host filesystem, not
    # inside the container, so /workspace would not exist without this.
    -e "HOST_PWD=$(pwd)"
  )
else
  warn "Running without Docker socket proxy — docker/compose commands unavailable"
fi

# ─── Wrap command to bootstrap project env first ───────────────────────────────
# If the project has a .mise.toml or .tool-versions, run `mise install` before
# the agent launches so the correct runtimes are available without manual setup.
if [[ -f "$(pwd)/.mise.toml" ]] || [[ -f "$(pwd)/.tool-versions" ]]; then
  bootstrap='eval "$(mise activate bash)" && mise install && '
else
  bootstrap='eval "$(mise activate bash)" && '
fi

final_cmd="${bootstrap}$(printf '%q ' "$@")"

# ─── Run ───────────────────────────────────────────────────────────────────────
log "Entering sandbox: $(pwd)"
log "Command: $*"
[[ -f "$(pwd)/.mise.toml" ]] && log "Found .mise.toml — runtimes will be installed automatically"
echo ""

exec docker run "${run_args[@]}" "$BOXOUT_IMAGE" bash -c "$final_cmd"
